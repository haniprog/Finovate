{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Start HTTP server (port 8080)",
            "type": "shell",
            "command": "python -m http.server 8080",
            "isBackground": true,
            "problemMatcher": {
                "owner": "http-server",
                "pattern": { "regexp": "^$" },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": ".",
                    "endsPattern": "Serving HTTP"
                }
            },
            "options": {
                "cwd": "${workspaceFolder}"
            }
        }
    ]
}
